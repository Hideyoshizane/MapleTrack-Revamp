{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": ["src/auth.ts"],
	"project": ["src/**/*.{ts,tsx}"],
	"ignore": [],
	"ignoreDependencies": ["eslint-config-next", "@svgr/webpack", "baseline-browser-mapping"],
	"ignoreBinaries": [],
	"ignoreExportsUsedInFile": {
		"interface": true,
		"type": true,
		"enum": true
	},
	"includeEntryExports": true,
	"eslint": {
		"config": ["eslint.config.js"],
		"entry": ["eslint.config.js"]
	},
	"typescript": {
		"config": ["tsconfig.json"]
	},
	"rules": {
		"files": "error",
		"dependencies": "error",
		"devDependencies": "error",
		"unlisted": "error",
		"unresolved": "error",
		"exports": "error",
		"types": "error",
		"duplicates": "error",
		"enumMembers": "warn",
		"nsExports": "warn",
		"nsTypes": "warn",
		"binaries": "warn"
	}
}
