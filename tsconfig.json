{
	"compilerOptions": {
		"baseUrl": "./",
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "ES2022", "ESNext"],
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noUnusedParameters": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"incremental": true,
		"noUnusedLocals": true,
		"forceConsistentCasingInFileNames": true,
		"useUnknownInCatchVariables": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"types": ["react", "react-dom", "@auth/core"],
		"paths": {
			"@/*": ["./src/*"],
			"@assets/*": ["./src/assets/*"],
			"@components/*": ["./src/components/*"],
			"@constants/*": ["./src/constants/*"],
			"@data/*": ["./src/data/*"],
			"@features/*": ["./src/features/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@lib/*": ["./src/lib/*"],
			"@schemas/*": ["./src/schemas/*"],
			"@sharedTypes/*": ["./src/shared/types/*"],
			"@store/*": ["./src/store/*"],
			"@utils/*": ["./src/utils/*"]
		},
		"allowJs": true
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"types/**/*.d.ts",
		"src/shared/types/**/*.d.ts"
	],
	"exclude": ["node_modules"]
}
