{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",

	"files": { "maxSize": 2097152, "includes": ["**", "!**/.next", "!**/.next/**"] },

	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 120,
		"lineEnding": "lf"
	},

	"assist": { "actions": { "source": { "organizeImports": "off" } } },

	"linter": { "enabled": false },

	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always",
			"bracketSpacing": true,
			"bracketSameLine": false
		}
	}
}
