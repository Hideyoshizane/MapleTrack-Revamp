{
	"depcheck": {
		"ignoreMatches": [
			"@svgr/webpack",
			"@lib/*",
			"@schemas/*",
			"@sharedTypes/*",
			"@models/*",
			"@components/*",
			"@assets/*",
			"@utils/*",
			"eslint-config-next",
			"eslint-plugin-react-hooks",
			"stylelint",
			"stylelint-config-standard",
			"stylelint-order"
		]
	}
}
